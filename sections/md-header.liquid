{{ 'md-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'md-header.js' | asset_url }}" defer="defer"></script>

{% style %}
  .md-header-section {
    position: sticky;
    top: 0;
    z-index: 3;
  }

  .shopify-section-header-sticky .md-header-section {
    top: calc(var(--header-top-offset, 0px));
  }
{% endstyle %}

<div class="md-header-section{% if section.settings.sticky_header %} md-header-section--sticky-always{% endif %}">
  {% if section.settings.show_trustbar %}
    {% render 'md-header-trustbar' %}
  {% endif %}

  <div class="md-header-main">
    <div class="md-header-main__inner">
      <button
        class="md-header-hamburger"
        type="button"
        aria-label="{{ 'sections.header.menu' | t }}"
        aria-expanded="false"
        aria-controls="md-header-drawer"
      >
        <span class="md-header-hamburger__icon">
          <span></span><span></span><span></span>
        </span>
      </button>

      <div class="md-header-logo">
        <a href="{{ routes.root_url }}" class="md-header-logo__link">
          {% if section.settings.logo_style == 'image' and settings.logo != blank %}
            {% assign logo_alt = settings.logo.alt | default: shop.name | escape %}
            {% assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio %}
            {{
              settings.logo
              | image_url: width: 300
              | image_tag:
                class: 'md-header-logo__image',
                width: settings.logo_width,
                height: logo_height,
                alt: logo_alt,
                preload: true
            }}
          {% else %}
            <span class="md-header-logo__text">{{ shop.name }}</span>
          {% endif %}
        </a>
      </div>

      {% if section.settings.show_search %}
        {% render 'md-header-search', mode: 'desktop' %}
      {% endif %}

      {% render 'md-header-icons' %}
    </div>

    {% if section.settings.show_search %}
      {% render 'md-header-search', mode: 'mobile' %}
    {% endif %}
  </div>

  {% if section.settings.show_category_bar %}
    {% render 'md-header-category-nav' %}
  {% endif %}

  {% assign menu = section.settings.menu %}

  <div class="md-header-drawer">
    <div class="md-header-drawer__overlay"></div>
    <div class="md-header-drawer__panel" id="md-header-drawer" role="dialog" aria-modal="true" aria-label="{{ 'sections.header.menu' | t }}">
      <div class="md-header-drawer__header">
        <span class="md-header-drawer__title">{{ 'sections.header.menu' | t }}</span>
        <button class="md-header-drawer__close" type="button" aria-label="{{ 'accessibility.close' | t }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
          </svg>
        </button>
      </div>

      <nav class="md-header-drawer__nav">
        <div class="md-header-drawer__level md-header-drawer__level--main is-active">
          <ul class="md-header-drawer__nav-list" role="list">
            {% if menu.links.size > 0 %}
              {% for link in menu.links %}
                <li class="md-header-drawer__nav-item">
                  {% if link.links.size > 0 %}
                    <button
                      class="md-header-drawer__nav-link md-header-drawer__nav-link--parent"
                      type="button"
                      data-drilldown-target="{{ forloop.index }}"
                    >
                      {{ link.title | escape }}
                    </button>
                  {% else %}
                    <a
                      href="{{ link.url }}"
                      class="md-header-drawer__nav-link"
                      {% if link.current %}aria-current="page"{% endif %}
                    >
                      {{ link.title | escape }}
                    </a>
                  {% endif %}
                </li>
              {% endfor %}
            {% endif %}
          </ul>

          <div class="md-header-drawer__specials">
            <p class="md-header-drawer__specials-title">Highlights</p>
            <a href="{{ routes.all_products_collection_url }}" class="md-header-drawer__special-link">Alle Produkte</a>
            {% if section.settings.show_b2b_hint and section.settings.b2b_business_url != blank %}
              <a href="{{ section.settings.b2b_business_url }}" class="md-header-drawer__special-link">
                {{ section.settings.b2b_business_text | escape }}
              </a>
            {% endif %}
          </div>

          <div class="md-header-drawer__footer">
            {% if shop.customer_accounts_enabled %}
              <a
                href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
                class="md-header-drawer__footer-link"
                rel="nofollow"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
                {% if customer %}{{ 'customer.account_fallback' | t }}{% else %}{{ 'customer.log_in' | t }}{% endif %}
              </a>
            {% endif %}

            {% if section.settings.show_service_link and section.settings.service_link != blank %}
              <a href="{{ section.settings.service_link }}" class="md-header-drawer__footer-link">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><line x1="9.09" y1="9" x2="16.16" y2="16.07"/><line x1="15" y1="9" x2="9" y2="15"/>
                </svg>
                {{ section.settings.service_label | escape }}
              </a>
            {% endif %}

            {% if section.settings.show_b2b_hint %}
              <span class="md-header-drawer__footer-text">
                {{ section.settings.b2b_private_text | escape }}
              </span>
            {% endif %}
          </div>
        </div>

        {% if menu.links.size > 0 %}
          {% for link in menu.links %}
            {% if link.links.size > 0 %}
              <div class="md-header-drawer__level md-header-drawer__level--child" data-drilldown-level="{{ forloop.index }}">
                <button class="md-header-drawer__back" type="button" aria-label="Zurück">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                  Zurück
                </button>
                <p class="md-header-drawer__level-title">{{ link.title | escape }}</p>
                <ul class="md-header-drawer__nav-list" role="list">
                  <li class="md-header-drawer__nav-item">
                    <a href="{{ link.url }}" class="md-header-drawer__nav-link md-header-drawer__nav-link--strong">
                      Alle anzeigen
                    </a>
                  </li>
                  {% for childlink in link.links %}
                    <li class="md-header-drawer__nav-item">
                      <a
                        href="{{ childlink.url }}"
                        class="md-header-drawer__nav-link"
                        {% if childlink.current %}aria-current="page"{% endif %}
                      >
                        {{ childlink.title | escape }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </nav>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Medical-Deal Header",
  "class": "md-header-section-wrapper",
  "max_blocks": 3,
  "settings": [
    {
      "type": "header",
      "content": "Logo"
