      "default": true,
      "label": "Suchleiste anzeigen"
    },
    {
      "type": "header",
      "content": "Kategorie-Leiste"
    },
    {
      "type": "checkbox",
      "id": "show_category_bar",
      "default": true,
      "label": "Kategorie-Leiste anzeigen"
    },
    {
      "type": "text",
      "id": "categories_label",
      "default": "Kategorien",
      "label": "Kategorien-Button Text"
    },
    {
      "type": "text",
      "id": "categories_all_label",
      "default": "Alle Kategorien",
      "label": "Alle Kategorien Link-Text"
