{{ 'md-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-facets.css' | asset_url | stylesheet_tag }}
<script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="md-collection color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  {%- paginate collection.products by section.settings.products_per_page -%}
    {%- liquid
      assign sidebar_links = null
      assign sidebar_heading = section.settings.sidebar_heading | default: 'Produktgruppen'
      assign hide_sidebar = true
      assign breadcrumb_parent_title = null
      assign breadcrumb_parent_url = null
      assign breadcrumb_current_title = collection.title
      assign breadcrumb_is_root = false

      if section.settings.show_sidebar
        if section.settings.sidebar_mode == 'manual'
          if section.settings.manual_sidebar_menu != blank
            assign manual_handle = section.settings.manual_sidebar_menu | strip
            if linklists[manual_handle].links.size > 0
              assign sidebar_links = linklists[manual_handle].links
              assign hide_sidebar = false
            endif
          endif
        elsif section.settings.sidebar_mode == 'auto' and section.settings.category_menu != blank
          assign cat_handle = section.settings.category_menu | strip
          if linklists[cat_handle].links.size > 0
            assign found_parent = false
            assign found_as_child = false
            for top_link in linklists[cat_handle].links
              if top_link.current
                assign sidebar_links = top_link.links
                assign sidebar_heading = top_link.title
                assign found_parent = true
                assign breadcrumb_is_root = true
                break
              else
                for child in top_link.links
                  if child.current
                    assign sidebar_links = top_link.links
                    assign sidebar_heading = top_link.title
                    assign found_as_child = true
                    assign breadcrumb_parent_title = top_link.title
                    assign breadcrumb_parent_url = top_link.url
                    assign breadcrumb_current_title = child.title
                    break
                  endif
                endfor
                if found_as_child
                  break
                endif
              endif
            endfor
            unless found_parent or found_as_child
              assign sidebar_links = linklists[cat_handle].links
            endunless
            if sidebar_links.size > 0
              assign hide_sidebar = false
            endif
          endif
        endif
      endif

      assign show_mobile_toggle = false
      if section.settings.show_sidebar and hide_sidebar == false
        assign show_mobile_toggle = true
      endif
    -%}

    {%- if show_mobile_toggle -%}
      <button
        class="md-collection-sidebar-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="md-collection-sidebar-drawer"
        onclick="document.getElementById('md-collection-sidebar-drawer').classList.add('is-open'); document.getElementById('md-collection-sidebar-overlay').classList.add('is-open');"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        {{- section.settings.sidebar_toggle_label | default: 'Kategorien' | escape -}}
      </button>
    {%- endif -%}

    <div class="md-collection-grid{% if hide_sidebar %} md-collection-grid--no-sidebar{% endif %}">
      {%- unless hide_sidebar -%}
        <aside class="md-collection-sidebar color-{{ section.settings.sidebar_color_scheme }}">
          <div class="md-collection-sidebar__inner">
            <div class="md-collection-sidebar__section">
              <h2 class="md-collection-sidebar__heading">{{ sidebar_heading | escape }}</h2>
              <ul class="md-collection-sidebar__list" role="list">
                {% for link in sidebar_links %}
                  <li>
                    <a
                      href="{{ link.url }}"
                      class="md-collection-sidebar__link{% if link.current %} md-collection-sidebar__link--active{% endif %}"
                      {% if link.current %}aria-current="page"{% endif %}
                    >
                      {%- if section.settings.show_sidebar_icons -%}
                        <span class="md-collection-sidebar__link-icon">
                          {%- render 'md-category-icon', title: link.title -%}
                        </span>
                      {%- endif -%}
                      <span class="md-collection-sidebar__link-text">{{ link.title | escape }}</span>
                      {%- if section.settings.show_sidebar_arrows and link.links.size > 0 -%}
                        <span class="md-collection-sidebar__link-arrow">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                        </span>
                      {%- endif -%}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            </div>

            {%- if section.settings.show_sidebar_banner -%}
              {%- if section.settings.sidebar_banner_image != blank -%}
                <a
                  href="{{ section.settings.sidebar_banner_link | default: '#' }}"
                  class="md-collection-sidebar__banner"
                  {% if section.settings.sidebar_banner_link == blank %}aria-disabled="true"{% endif %}
                >
                  {{
                    section.settings.sidebar_banner_image
                    | image_url: width: 400
                    | image_tag:
                      class: 'md-collection-sidebar__banner-image',
                      alt: section.settings.sidebar_banner_image.alt | default: 'Werbung',
                      loading: 'lazy'
                  }}
                </a>
              {%- else -%}
                <div class="md-collection-sidebar__banner" style="position:relative;">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" class="md-collection-sidebar__banner-image" width="400" height="300" aria-label="Werbebanner Platzhalter" style="display:block;width:100%;height:auto;">
                    <rect width="400" height="300" fill="rgb(var(--color-background))"/>
                    <rect x="80" y="110" width="240" height="80" rx="4" fill="rgb(var(--color-foreground))" opacity="0.08"/>
                    <text x="200" y="155" text-anchor="middle" fill="rgb(var(--color-foreground))" font-family="system-ui, sans-serif" font-size="15" font-weight="500" opacity="0.5">Werbebanner</text>
                    <text x="200" y="175" text-anchor="middle" fill="rgb(var(--color-foreground))" font-family="system-ui, sans-serif" font-size="11" opacity="0.35">400 × 300 px</text>
                  </svg>
                </div>
              {%- endif -%}
            {%- endif -%}

            {%- if section.settings.sidebar_links_menu != blank -%}
              {% assign links_menu_handle = section.settings.sidebar_links_menu | strip %}
              {% if linklists[links_menu_handle].links.size > 0 %}
                <div class="md-collection-sidebar__links">
                  <h3 class="md-collection-sidebar__links-heading">{{ section.settings.sidebar_links_heading | default: 'Interessante Links' | escape }}</h3>
                  <ul class="md-collection-sidebar__links-list" role="list">
                    {% for link in linklists[links_menu_handle].links %}
                      <li class="md-collection-sidebar__links-item">
                        <a href="{{ link.url }}" class="md-collection-sidebar__links-link">{{ link.title | escape }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}
            {%- endif -%}
          </div>
        </aside>
      {%- endunless -%}

      <div class="md-collection-content">
        {%- if section.settings.show_breadcrumb and section.settings.category_menu != blank and breadcrumb_parent_title != null or breadcrumb_is_root -%}
          <nav class="md-collection-breadcrumb" aria-label="Navigationspfad" style="padding: 0.8rem 0 0; font-size: var(--md-collection-font-xs); color: rgba(var(--color-foreground), 0.55);">
            <a href="{{ routes.root_url }}" style="color: inherit; text-decoration: none;">Startseite</a>
            {%- if breadcrumb_parent_title != null -%}
              <span aria-hidden="true"> / </span>
              <a href="{{ breadcrumb_parent_url }}" style="color: inherit; text-decoration: none;">{{ breadcrumb_parent_title | escape }}</a>
              <span aria-hidden="true"> / </span>
              <span aria-current="page">{{ breadcrumb_current_title | escape }}</span>
            {%- elsif breadcrumb_is_root -%}
              <span aria-hidden="true"> / </span>
              <span aria-current="page">{{ breadcrumb_current_title | escape }}</span>
            {%- endif -%}
          </nav>
        {%- endif -%}

        <div class="md-collection-page-header">
          <h1 class="md-collection-page-title">
            {{- collection.title | escape -}}
            <span class="md-collection-page-counter">
              {%- if collection.results_count -%}
                {{ collection.results_count }} {{ 'products.facets.product_count_simple.other' | t: count: collection.results_count | strip_html | split: ' ' | last | default: 'Artikel' }}
              {%- else -%}
                {{ collection.all_products_count }} Artikel
              {%- endif -%}
            </span>
          </h1>

          {%- if section.settings.show_collection_description and collection.description != blank -%}
            <div class="md-collection-page-description rte">
              {{ collection.description }}
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.show_collection_image and collection.image -%}
          <div class="md-collection-page-image">
            <img
              src="{{ collection.image | image_url: width: 1400 }}"
              srcset="
                {{ collection.image | image_url: width: 360 }} 360w,
                {{ collection.image | image_url: width: 720 }} 720w,
                {{ collection.image | image_url: width: 1080 }} 1080w,
                {{ collection.image | image_url: width: 1400 }} 1400w
              "
              sizes="(min-width: 1400px) 1064px, (min-width: 990px) calc(76vw - 4rem), calc(100vw - 3rem)"
              alt="{{ collection.image.alt | default: collection.title | escape }}"
              width="{{ collection.image.width }}"
              height="{{ collection.image.height }}"
              loading="eager"
            >
          </div>
        {%- endif -%}

        {%- if section.settings.show_promo_tiles and section.blocks.size > 0 -%}
          <div class="md-collection-promos">
            {%- for block in section.blocks limit: 3 -%}
              {%- if block.type == 'promo_tile' -%}
                {%- if block.settings.promo_image != blank -%}
                  <a
                    href="{{ block.settings.promo_link | default: '#' }}"
                    class="md-collection-promo color-{{ section.settings.promo_color_scheme }}"
                    {% if block.settings.promo_link == blank %}aria-disabled="true"{% endif %}
                    {{ block.shopify_attributes }}
                  >
                    {{
                      block.settings.promo_image
                      | image_url: width: 600
                      | image_tag:
                        class: 'md-collection-promo__image',
                        alt: block.settings.promo_heading | default: 'Promo',
                        loading: 'lazy'
                    }}
                    {%- if block.settings.promo_heading != blank or block.settings.promo_text != blank -%}
                      <span class="md-collection-promo__content color-{{ section.settings.promo_color_scheme }}">
                        {%- if block.settings.promo_heading != blank -%}
                          <span class="md-collection-promo__caption">{{ block.settings.promo_heading | escape }}</span>
                        {%- endif -%}
                        {%- if block.settings.promo_text != blank -%}
                          <span class="md-collection-promo__text">{{ block.settings.promo_text | escape }}</span>
                        {%- endif -%}
                      </span>
                    {%- endif -%}
                  </a>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if collection.products.size == 0 -%}
          <div class="md-collection-empty">
            <h2 class="md-collection-empty__title">{{ 'sections.collection_template.empty' | t }}</h2>
            <p class="md-collection-empty__text">
              {{ 'sections.collection_template.use_fewer_filters_html' | t: link: collection.url, class: 'underlined-link link' }}
            </p>
          </div>
        {%- else -%}
          {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            <div class="md-collection-toolbar">
              <div class="md-collection-toolbar__inner">
                <div class="md-collection-toolbar__left">
                  {%- if section.settings.enable_filtering -%}
                    <button
                      type="button"
                      class="md-collection-toolbar__filter-btn"
                      aria-expanded="false"
                      aria-controls="md-collection-filters-drawer"
                      onclick="document.getElementById('md-collection-filters-drawer').classList.toggle('is-open');document.getElementById('md-collection-filters-overlay').classList.toggle('is-open');this.setAttribute('aria-expanded',document.getElementById('md-collection-filters-drawer').classList.contains('is-open'));"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="2" y1="4" x2="14" y2="4"/><line x1="3" y1="8" x2="13" y2="8"/><line x1="4" y1="12" x2="12" y2="12"/>
                      </svg>
                      {{- 'products.facets.filter_button' | t -}}
                    </button>
                  {%- endif -%}
                  <span class="visually-hidden" id="ProductCount" role="status">
                    {%- if collection.results_count -%}
                      {{ 'templates.search.results_with_count' | t: terms: collection.terms, count: collection.results_count }}
                    {%- elsif collection.products_count == collection.all_products_count -%}
                      {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
                    {%- else -%}
                      {{ 'products.facets.product_count' | t: product_count: collection.products_count, count: collection.all_products_count }}
                    {%- endif -%}
                  </span>
                  <span class="md-collection-toolbar__count product-count" role="status">
                    <span class="product-count__text text-body" id="ProductCountDesktop">
                      {%- if collection.results_count -%}
                        {{ 'templates.search.results_with_count' | t: terms: collection.terms, count: collection.results_count }}
                      {%- elsif collection.products_count == collection.all_products_count -%}
                        {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
                      {%- else -%}
                        {{ 'products.facets.product_count' | t: product_count: collection.products_count, count: collection.all_products_count }}
                      {%- endif -%}
                    </span>
                  </span>
                </div>

                <div class="md-collection-toolbar__right">
                  {%- if section.settings.enable_sorting -%}
                    <facet-filters-form class="md-collection-toolbar__sort-form">
                      <form id="FacetSortForm">
                        <div class="facet-filters__field">
                          <label for="SortBy" class="facet-filters__label">{{ 'products.facets.sort_by_label' | t }}</label>
                          <div class="select">
                            <select
                              name="sort_by"
                              class="select__select"
                              id="SortBy"
                              aria-describedby="a11y-refresh-page-message"
                            >
                              {%- for option in collection.sort_options -%}
                                <option value="{{ option.value | escape }}"{% if option.value == sort_by %} selected="selected"{% endif %}>
                                  {{ option.name | escape }}
                                </option>
                              {%- endfor -%}
                            </select>
                            <span class="svg-wrapper">
                              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </span>
                          </div>
                        </div>
                      </form>
                    </facet-filters-form>
                  {%- endif -%}
                </div>
              </div>

              {%- if section.settings.enable_filtering -%}
                {%- liquid
                  assign total_active_values = 0
                  for filter in collection.filters
                    assign total_active_values = total_active_values | plus: filter.active_values.size
                    if filter.type == 'price_range'
                      if filter.min_value.value != null or filter.max_value.value != null
                        assign total_active_values = total_active_values | plus: 1
                      endif
                    endif
                  endfor
                -%}
                <div class="md-collection-toolbar__active{% if total_active_values == 0 %} is-empty{% endif %}">
                  <div class="active-facets active-facets-desktop">
                    {%- if total_active_values > 0 -%}
                      {%- for filter in collection.filters -%}
                        {%- for value in filter.active_values -%}
                          <facet-remove>
                            <a href="{{ value.url_to_remove }}" class="md-active-filter-chip active-facets__button">
                              <span class="md-active-filter-chip__inner active-facets__button-inner">
                                <span class="md-active-filter-chip__label">{{ value.label | escape }}</span>
                                <span class="md-active-filter-chip__remove" aria-hidden="true">&times;</span>
                              </span>
                            </a>
                          </facet-remove>
                        {%- endfor -%}
                        {% if filter.type == 'price_range' %}
                          {%- assign min = filter.min_value.value -%}
                          {%- assign max = filter.max_value.value -%}
                          {%- if min != null or max != null -%}
                            <facet-remove>
                              <a href="{{ filter.url_to_remove }}" class="md-active-filter-chip active-facets__button">
                                <span class="md-active-filter-chip__inner active-facets__button-inner">
                                  {%- if min != null -%}<span class="md-active-filter-chip__label">{{ min | money }}</span>{%- endif -%}
                                  {%- if min != null and max != null %} <span class="md-active-filter-chip__label">&ndash;</span> {% endif -%}
                                  {%- if max != null -%}<span class="md-active-filter-chip__label">{{ max | money }}</span>{%- endif -%}
                                  <span class="md-active-filter-chip__remove" aria-hidden="true">&times;</span>
                                </span>
                              </a>
                            </facet-remove>
                          {%- endif -%}
                        {% endif %}
                      {%- endfor -%}
                      <facet-remove class="md-active-filter-chip__clear-wrapper active-facets__button-wrapper">
                        <a href="{{ collection.url }}" class="active-facets__button-remove underlined-link">
                          <span>{{ 'products.facets.clear_all' | t }}</span>
                        </a>
                      </facet-remove>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            </div>

            {%- if section.settings.enable_filtering -%}
              <div class="md-collection-filters-drawer" id="md-collection-filters-drawer">
                <div class="md-collection-filters-drawer__header">
                  <h2 class="md-collection-filters-drawer__title">{{ 'products.facets.filter_button' | t }}</h2>
                  <button
                    type="button"
                    class="md-collection-filters-drawer__close"
                    aria-label="{{ 'accessibility.close' | t }}"
                    onclick="document.getElementById('md-collection-filters-drawer').classList.remove('is-open'); document.getElementById('md-collection-filters-overlay').classList.remove('is-open');"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 4l-8 8M4 4l8 8"/></svg>
                  </button>
                </div>
                <div class="md-collection-filters-drawer__body">
                  <facet-filters-form class="facets">
                    <form id="FacetFiltersForm" class="facets__form-drawer">
                      <div id="FacetsWrapperDesktop" class="facets__wrapper-drawer">
                        {%- for filter in collection.filters -%}

                          {% case filter.type %}
                            {% when 'boolean', 'list' %}
                              <details
                                id="Details-{{ filter.param_name | escape }}-{{ section.id }}"
                                class="md-collection-filters-drawer__group js-filter"
                                data-index="{{ forloop.index }}"
                                {% if filter.active_values.size > 0 %}open{% endif %}
                              >
                                <summary class="md-collection-filters-drawer__group-header facets__summary">
                                  <span>{{ filter.label | escape }}</span>
                                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </summary>
                                <div id="Facet-{{ forloop.index }}-{{ section.id }}" class="md-collection-filters-drawer__group-body facets-wrap parent-wrap">
                                  <ul class="md-collection-filters-drawer__list facets__list list-unstyled" role="list">
                                    {%- liquid
                                      assign sorted_values = filter.values
                                      if filter.operator == 'AND'
                                        assign active_filter_values = filter.values | where: 'active', true
                                        assign inactive_filter_values = filter.values | where: 'active', false
                                        assign sorted_values = active_filter_values | concat: inactive_filter_values
                                      endif
                                    -%}
                                    {%- for value in sorted_values -%}
                                      {%- liquid
                                        assign input_id = 'Filter-' | append: filter.param_name | escape | append: '-' | append: forloop.index
                                        assign is_disabled = false
                                        if value.count == 0 and value.active == false
                                          assign is_disabled = true
                                        endif
                                      -%}
                                      <li class="md-collection-filters-drawer__item">
                                        <label for="{{ input_id }}" class="md-collection-filters-drawer__label facet-checkbox{% if is_disabled %} md-collection-filters-drawer__label--disabled{% endif %}{% if value.active %} md-collection-filters-drawer__label--active{% endif %}">
                                          <input
                                            type="checkbox"
                                            name="{{ value.param_name }}"
                                            value="{{ value.value }}"
                                            id="{{ input_id }}"
                                            {% if value.active %}checked{% endif %}
                                            {% if is_disabled %}disabled{% endif %}
                                          >
                                          <span class="md-collection-filters-drawer__check">
                                            <svg class="icon icon-checkmark" width="1.1rem" height="0.7rem" viewBox="0 0 11 7" fill="none" xmlns="http://www.w3.org/2000/svg">
                                              <path d="M1.5 3.5L4 6.5L9.5 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                            </svg>
                                          </span>
                                          <span class="facet-checkbox__text" aria-hidden="true">
                                            <span class="facet-checkbox__text-label">{{ value.label | escape }}</span>
                                          </span>
                                          <span class="md-collection-filters-drawer__item-count">({{ value.count }})</span>
                                          <span class="visually-hidden">{{ value.label | escape }} ({{ value.count }})</span>
                                        </label>
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                </div>
                              </details>
                            {% when 'price_range' %}
                              <details
                                id="Details-{{ filter.param_name | escape }}-{{ section.id }}"
                                class="md-collection-filters-drawer__group js-filter"
                                data-index="{{ forloop.index }}"
                                {% if filter.min_value.value or filter.max_value.value %}open{% endif %}
                              >
                                <summary class="md-collection-filters-drawer__group-header">
                                  <span>{{ filter.label | escape }}</span>
                                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </summary>
                                <div id="Facet-{{ forloop.index }}-{{ section.id }}" class="md-collection-filters-drawer__group-body">
                                  <p class="md-collection-filters-drawer__price-hint">{{ 'products.facets.max_price' | t: price: filter.range_max | money }}</p>
                                  <price-range class="facets__price">
                                    <span class="field-currency">{{ cart.currency.symbol }}</span>
                                    <div class="field">
                                      <input
                                        class="field__input"
                                        name="{{ filter.min_value.param_name }}"
                                        id="Filter-{{ filter.label | escape }}-GTE"
                                        {%- if filter.min_value.value -%}
                                          value="{{ filter.min_value.value | divided_by: 100.00 }}"
                                        {%- endif -%}
                                        type="number"
                                        placeholder="0"
                                        min="0"
                                        max="{{ filter.range_max | divided_by: 100.00 | ceil }}"
                                      >
                                      <label class="field__label" for="Filter-{{ filter.label | escape }}-GTE">{{ 'products.facets.from' | t }}</label>
                                    </div>
                                    <span class="field-currency">{{ cart.currency.symbol }}</span>
                                    <div class="field">
                                      <input
                                        class="field__input"
                                        name="{{ filter.max_value.param_name }}"
                                        id="Filter-{{ filter.label | escape }}-LTE"
                                        {%- if filter.max_value.value -%}
                                          value="{{ filter.max_value.value | divided_by: 100.00 }}"
                                        {%- endif -%}
                                        type="number"
                                        min="0"
                                        placeholder="{{ filter.range_max | divided_by: 100.00 | ceil }}"
                                        max="{{ filter.range_max | divided_by: 100.00 | ceil }}"
                                      >
                                      <label class="field__label" for="Filter-{{ filter.label | escape }}-LTE">{{ 'products.facets.to' | t }}</label>
                                    </div>
                                  </price-range>
                                </div>
                              </details>
                          {% endcase %}
                        {%- endfor -%}
                      </div>
                    </form>
                  </facet-filters-form>
                </div>
                <div class="md-collection-filters-drawer__footer">
                  <facet-remove>
                    <a href="{{ collection.url }}" class="button button--secondary full-unstyled-link">{{ 'products.facets.clear_all' | t }}</a>
                  </facet-remove>
                  <button
                    type="button"
                    class="button button--primary"
                    onclick="document.getElementById('md-collection-filters-drawer').classList.remove('is-open'); document.getElementById('md-collection-filters-overlay').classList.remove('is-open');"
                  >
                    {{ 'products.facets.apply' | t }}
                  </button>
                </div>
              </div>

              <div class="md-collection-filters-overlay" id="md-collection-filters-overlay" onclick="document.getElementById('md-collection-filters-drawer').classList.remove('is-open'); this.classList.remove('is-open');"></div>

              {% comment %} Minimal mobile facets stub for facets.js compatibility — structure kept, value loops stripped {% endcomment %}
              <div style="display:none" aria-hidden="true">
                <menu-drawer>
                  <details>
                    <summary></summary>
                    <facet-filters-form>
                      <form id="FacetFiltersFormMobile" class="mobile-facets">
                        <div class="mobile-facets__inner">
                          <div class="mobile-facets__header">
                            <h2 class="mobile-facets__heading">Filter</h2>
                            <p class="mobile-facets__count"></p>
                          </div>
                          <div id="FacetsWrapperMobile" class="mobile-facets__main">
                            {%- for filter in collection.filters -%}
                              {% case filter.type %}
                                {% when 'boolean', 'list' %}
                                  <details id="Details-Mobile-{{ filter.param_name | escape }}-{{ section.id }}" class="mobile-facets__details js-filter" data-index="mobile-{{ forloop.index }}">
                                    <summary class="mobile-facets__summary"><span>{{ filter.label | escape }}</span></summary>
                                    <div id="FacetMobile-{{ forloop.index }}-{{ section.id }}" class="mobile-facets__submenu">
                                      <ul class="mobile-facets__list list-unstyled"></ul>
                                    </div>
                                  </details>
                                {% when 'price_range' %}
                                  <details id="Details-Mobile-{{ filter.param_name | escape }}-{{ section.id }}" class="mobile-facets__details js-filter" data-index="mobile-{{ forloop.index }}">
                                    <summary class="mobile-facets__summary"><span>{{ filter.label | escape }}</span></summary>
                                    <div id="FacetMobile-{{ forloop.index }}-{{ section.id }}" class="mobile-facets__submenu">
                                      <price-range class="facets__price"></price-range>
                                    </div>
                                  </details>
                              {% endcase %}
                            {%- endfor -%}
                          </div>
                        </div>
                      </form>
                    </facet-filters-form>
                  </details>
                </menu-drawer>
              </div>
            {%- endif -%}
          {%- endif -%}

          {% comment %} Product Grid {% endcomment %}
          <div
            class="product-grid-container"
            id="ProductGridContainer"
          >
            <div class="collection">
              <div class="loading-overlay"></div>
              <div
                class="md-collection-products"
                id="product-grid"
                data-id="{{ section.id }}"
                style="--md-collection-columns-mobile: {{ section.settings.columns_mobile }}; --md-collection-columns-tablet: {{ section.settings.columns_tablet }}; --md-collection-columns-desktop: {{ section.settings.columns_desktop }};"
              >
                {%- for product in collection.products -%}
                  {%- assign lazy_load = true -%}
                  {%- if forloop.index <= 2 -%}
                    {%- assign lazy_load = false -%}
                  {%- endif -%}
                  {% render 'md-card-product',
                    card_product: product,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    show_inventory: section.settings.show_inventory,
                    show_unit_price: section.settings.show_unit_price,
                    show_variant_hint: section.settings.show_variant_hint,
                    lazy_load: lazy_load,
                    section_id: section.id
                  %}
                {%- endfor -%}
              </div>
            </div>
          </div>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
          <div class="md-collection-pagination">
            <ul class="md-collection-pagination__list" role="list">
              {%- if paginate.previous -%}
                <li class="md-collection-pagination__item">
                  <a href="{{ paginate.previous.url }}" class="md-collection-pagination__link md-collection-pagination__link--arrow" aria-label="{{ 'general.pagination.previous' | t }}">
                    ‹
                  </a>
                </li>
              {%- else -%}
                <li class="md-collection-pagination__item">
                  <span class="md-collection-pagination__link md-collection-pagination__link--arrow md-collection-pagination__link--disabled">‹</span>
                </li>
              {%- endif -%}

              {%- for part in paginate.parts -%}
                <li class="md-collection-pagination__item">
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}" class="md-collection-pagination__link" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">{{ part.title }}</a>
                  {%- else -%}
                    <span class="md-collection-pagination__link md-collection-pagination__link--current" aria-current="page">{{ part.title }}</span>
                  {%- endif -%}
                </li>
              {%- endfor -%}

              {%- if paginate.next -%}
                <li class="md-collection-pagination__item">
                  <a href="{{ paginate.next.url }}" class="md-collection-pagination__link md-collection-pagination__link--arrow" aria-label="{{ 'general.pagination.next' | t }}">
                    ›
                  </a>
                </li>
              {%- else -%}
                <li class="md-collection-pagination__item">
                  <span class="md-collection-pagination__link md-collection-pagination__link--arrow md-collection-pagination__link--disabled">›</span>
                </li>
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
</div>

{%- if show_mobile_toggle -%}
  <div
    id="md-collection-sidebar-overlay"
    class="md-collection-sidebar-drawer__overlay"
    onclick="document.getElementById('md-collection-sidebar-drawer').classList.remove('is-open'); this.classList.remove('is-open');"
  ></div>
  <aside
    id="md-collection-sidebar-drawer"
    class="md-collection-sidebar-drawer color-{{ section.settings.sidebar_color_scheme }}"
  >
    <div class="md-collection-sidebar-drawer__header">
      <h2 class="md-collection-sidebar-drawer__title">{{ sidebar_heading | escape }}</h2>
      <button
        class="md-collection-sidebar-drawer__close"
        type="button"
        aria-label="{{ 'accessibility.close' | t }}"
        onclick="document.getElementById('md-collection-sidebar-drawer').classList.remove('is-open'); document.getElementById('md-collection-sidebar-overlay').classList.remove('is-open');"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="md-collection-sidebar-drawer__content">
      {%- unless hide_sidebar -%}
        <ul class="md-collection-sidebar__list" role="list">
          {% for link in sidebar_links %}
            <li>
              <a
                href="{{ link.url }}"
                class="md-collection-sidebar__link{% if link.current %} md-collection-sidebar__link--active{% endif %}"
                {% if link.current %}aria-current="page"{% endif %}
              >
                {%- if section.settings.show_sidebar_icons -%}
                  <span class="md-collection-sidebar__link-icon">
                    {%- render 'md-category-icon', title: link.title -%}
                  </span>
                {%- endif -%}
                <span class="md-collection-sidebar__link-text">{{ link.title | escape }}</span>
              </a>
            </li>
          {% endfor %}
        </ul>
      {%- endunless -%}

      {%- if section.settings.show_sidebar_banner -%}
        {%- if section.settings.sidebar_banner_image != blank -%}
        <a
          href="{{ section.settings.sidebar_banner_link | default: '#' }}"
          class="md-collection-sidebar__banner"
          style="margin-top: 1.6rem;"
          {% if section.settings.sidebar_banner_link == blank %}aria-disabled="true"{% endif %}
        >
          {{
            section.settings.sidebar_banner_image
            | image_url: width: 400
            | image_tag:
              class: 'md-collection-sidebar__banner-image',
              alt: section.settings.sidebar_banner_image.alt | default: 'Werbung',
              loading: 'lazy'
          }}
        </a>
        {%- else -%}
        <div class="md-collection-sidebar__banner" style="margin-top:1.6rem;position:relative;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" class="md-collection-sidebar__banner-image" width="400" height="300" aria-label="Werbebanner Platzhalter" style="display:block;width:100%;height:auto;">
            <rect width="400" height="300" fill="rgb(var(--color-background))"/>
            <rect x="80" y="110" width="240" height="80" rx="4" fill="rgb(var(--color-foreground))" opacity="0.08"/>
            <text x="200" y="155" text-anchor="middle" fill="rgb(var(--color-foreground))" font-family="system-ui, sans-serif" font-size="15" font-weight="500" opacity="0.5">Werbebanner</text>
            <text x="200" y="175" text-anchor="middle" fill="rgb(var(--color-foreground))" font-family="system-ui, sans-serif" font-size="11" opacity="0.35">400 × 300 px</text>
          </svg>
        </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </aside>
{%- endif -%}

{% schema %}
{
  "name": "MD Hauptkollektion",
  "class": "section",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "promo_tile",
      "name": "Promo-Kachel",
      "settings": [
        {
          "type": "image_picker",
          "id": "promo_image",
          "label": "Bild"
        },
        {
          "type": "text",
          "id": "promo_heading",
          "label": "Überschrift",
          "default": "Jetzt entdecken"
        },
        {
          "type": "text",
          "id": "promo_text",
          "label": "Text (optional)"
        },
        {
          "type": "url",
          "id": "promo_link",
          "label": "Link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema Hauptbereich",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_sidebar",
      "label": "Seitenleiste anzeigen",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "sidebar_color_scheme",
      "label": "Farbschema Seitenleiste",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "sidebar_heading",
      "label": "Überschrift Seitenleiste",
      "default": "Produktgruppen"
    },
    {
      "type": "select",
      "id": "sidebar_mode",
      "label": "Sidebar-Modus",
      "options": [
        { "value": "auto", "label": "Automatisch (Kontext aus Kategorie-Menü)" },
        { "value": "manual", "label": "Manuell" }
      ],
      "default": "auto"
    },
    {
      "type": "link_list",
      "id": "category_menu",
      "label": "Kategorie-Menü für Sidebar-Logik",
      "info": "Wird für automatische Sidebar + Breadcrumbs verwendet"
    },
    {
      "type": "link_list",
      "id": "manual_sidebar_menu",
      "label": "Manuelles Sidebar-Menü",
      "info": "Wird nur bei Modus 'Manuell' verwendet"
    },
    {
      "type": "checkbox",
      "id": "show_sidebar_icons",
      "label": "Sidebar-Icons anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sidebar_arrows",
      "label": "Sidebar-Pfeile anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "sidebar_toggle_label",
      "label": "Aufklapp-Button Beschriftung (Mobile)",
      "default": "Kategorien"
    },
    {
      "type": "header",
      "content": "Seitenleiste: Werbebanner"
    },
    {
      "type": "checkbox",
      "id": "show_sidebar_banner",
      "label": "Werbebanner anzeigen",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "sidebar_banner_image",
      "label": "Banner-Bild",
      "info": "Empfohlen: 400 × 300 px (Verhältnis 4:3)"
    },
    {
      "type": "url",
      "id": "sidebar_banner_link",
      "label": "Banner-Link"
    },
    {
      "type": "header",
      "content": "Seitenleiste: Interessante Links"
    },
    {
      "type": "link_list",
      "id": "sidebar_links_menu",
      "label": "Menü für interessante Links",
      "info": "Unterer Link-Block in der Sidebar"
    },
    {
      "type": "text",
      "id": "sidebar_links_heading",
      "label": "Überschrift Link-Block",
      "default": "Interessante Links"
    },
    {
      "type": "header",
      "content": "Seitenkopf"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "label": "Beschreibung anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "Kollektionsbild anzeigen",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Breadcrumb anzeigen",
      "default": true
    },
    {
      "type": "header",
      "content": "Promo-Kacheln"
    },
    {
      "type": "checkbox",
      "id": "show_promo_tiles",
      "label": "Promo-Kacheln anzeigen",
      "default": true,
      "info": "Füge bis zu 3 Promo-Kacheln als Blöcke hinzu"
    },
    {
      "type": "color_scheme",
      "id": "promo_color_scheme",
      "label": "Farbschema Promo-Kacheln",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Produktgrid"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16,
      "label": "Produkte pro Seite"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Spalten Desktop (≥990px)",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Spalten Tablet (750–989px)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Spalten Mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Produktkarte"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Hersteller anzeigen",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Bewertungen anzeigen",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_inventory",
      "label": "Lagerbestand anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_unit_price",
      "label": "Grundpreis anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_variant_hint",
      "label": "Varianten-Hinweis anzeigen",
      "default": true,
      "info": "Zeigt z.B. '3 Packgrößen'"
    },
    {
      "type": "header",
      "content": "Filter & Sortierung"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Filtern aktivieren",
      "default": true
    },
    {
      "type": "select",
      "id": "filter_type",
      "label": "Filter-Typ",
      "options": [
        { "value": "horizontal", "label": "Horizontal" },
        { "value": "drawer", "label": "Drawer (nur Mobile)" }
      ],
      "default": "horizontal"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Sortierung aktivieren",
      "default": true
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 28
    }
  ]
}
{% endschema %}
