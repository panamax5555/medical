{{ 'md-trustbar.css' | asset_url | stylesheet_tag }}

<div class="md-trustbar color-{{ section.settings.color_scheme }} gradient">
  <div class="md-trustbar__inner">
    {% assign trust_items = '1,2,3,4' | split: ',' %}
    {% for t in trust_items %}
      {% assign t_icon_key = 'trust_' | append: t | append: '_icon' %}
      {% assign t_custom_icon_key = 'trust_' | append: t | append: '_custom_icon' %}
      {% assign t_title_key = 'trust_item_' | append: t | append: '_title' %}
      {% assign t_text_key = 'trust_item_' | append: t | append: '_text' %}
      <div class="md-trustbar__item">
        <div class="md-trustbar__icon">
          {% if section.settings[t_custom_icon_key] != blank %}
            {% assign trust_img_alt = section.settings[t_title_key] | escape %}
            {{
              section.settings[t_custom_icon_key]
              | image_url: width: 96
              | image_tag:
                class: 'md-trustbar__custom-icon',
                width: 48,
                height: 48,
                alt: trust_img_alt,
                loading: 'lazy'
            }}
          {% else %}
            {% render 'md-footer-icon', icon: section.settings[t_icon_key] %}
          {% endif %}
        </div>
        <p class="md-trustbar__title">{{ section.settings[t_title_key] | escape }}</p>
        <p class="md-trustbar__text">{{ section.settings[t_text_key] | escape }}</p>
      </div>
    {% endfor %}
  </div>
</div>

