{{ 'md-footer.css' | asset_url | stylesheet_tag }}

<footer class="md-footer-section color-{{ section.settings.color_scheme }} gradient">
  <div class="md-footer-main">
    <div class="md-footer-main__inner">
      <div class="md-footer-grid">

        <div class="md-footer-col">
          {% if section.settings.show_logo %}
            {% if section.settings.footer_logo != blank %}
              {% assign flogo_alt = section.settings.footer_logo.alt | default: shop.name | escape %}
              {{
                section.settings.footer_logo
                | image_url: width: 320
                | image_tag:
                  class: 'md-footer-brand__logo',
                  width: section.settings.footer_logo.width,
                  height: section.settings.footer_logo.height,
                  alt: flogo_alt,
                  loading: 'lazy'
              }}
            {% elsif settings.logo != blank %}
              {% assign logo_alt = settings.logo.alt | default: shop.name | escape %}
              {% assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio %}
              {{
                settings.logo
                | image_url: width: 320
                | image_tag:
                  class: 'md-footer-brand__logo',
                  width: settings.logo_width,
                  height: logo_height,
                  alt: logo_alt,
                  loading: 'lazy'
              }}
            {% endif %}
          {% endif %}
          {% if section.settings.company_description != blank %}
            <p class="md-footer-brand__text">{{ section.settings.company_description | escape }}</p>
          {% endif %}
          {% if section.settings.company_address != blank or section.settings.company_email != blank or section.settings.company_phone != blank %}
            <p class="md-footer-brand__contact">
              {% if section.settings.company_address != blank %}
                {{ section.settings.company_address | escape }}<br>
              {% endif %}
              {% if section.settings.company_email != blank %}
                <a href="mailto:{{ section.settings.company_email | escape }}">{{ section.settings.company_email | escape }}</a><br>
              {% endif %}
              {% if section.settings.company_phone != blank %}
                <a href="tel:{{ section.settings.company_phone | replace: ' ', '' | escape }}">{{ section.settings.company_phone | escape }}</a>
              {% endif %}
            </p>
          {% endif %}
        </div>

        {% assign menu_columns = 'assortment,service,company,legal' | split: ',' %}
        {% for col in menu_columns %}
          {% assign menu_key = col | prepend: 'menu_' %}
          {% assign heading_key = col | prepend: 'heading_' %}
          {% assign menu_handle = section.settings[menu_key] | strip %}
          {% assign menu_links = linklists[menu_handle].links %}

          <div class="md-footer-col">
            <details open>
              <summary>{{ section.settings[heading_key] | escape }}</summary>
              <ul class="md-footer-col__list md-footer-col__list--accordion" role="list">
                {% if menu_links.size > 0 %}
                  {% for menu_link in menu_links %}
                    <li>
                      <a href="{{ menu_link.url }}" class="md-footer-col__link">
                        {{ menu_link.title | escape }}
                      </a>
                    </li>
                  {% endfor %}
                {% else %}
                  {% case col %}
                    {% when 'assortment' %}
                      <li><a href="{{ routes.all_products_collection_url }}" class="md-footer-col__link">Einmalhandschuhe</a></li>
                      <li><a href="{{ routes.all_products_collection_url }}" class="md-footer-col__link">Desinfektion</a></li>
                      <li><a href="{{ routes.all_products_collection_url }}" class="md-footer-col__link">Reinigung</a></li>
                      <li><a href="{{ routes.all_products_collection_url }}" class="md-footer-col__link">Papier & Tücher</a></li>
                      <li><a href="{{ routes.all_products_collection_url }}" class="md-footer-col__link">Schutzkleidung</a></li>
                      <li><a href="{{ routes.all_products_collection_url }}" class="md-footer-col__link">Pflegehilfsmittel</a></li>
                      <li><a href="{{ routes.all_products_collection_url }}" class="md-footer-col__link">Praxisbedarf</a></li>
                    {% when 'service' %}
                      <li><a href="/pages/versand-lieferung" class="md-footer-col__link">Versand & Lieferung</a></li>
                      <li><a href="/pages/zahlungsarten" class="md-footer-col__link">Zahlungsarten</a></li>
                      <li><a href="/pages/geschaeftskunde-werden" class="md-footer-col__link">Geschäftskunde werden</a></li>
                      <li><a href="/pages/mengenanfrage" class="md-footer-col__link">Mengenanfrage</a></li>
                      <li><a href="/pages/hilfe-faq" class="md-footer-col__link">Hilfe / FAQ</a></li>
                      <li><a href="/pages/contact" class="md-footer-col__link">Kontakt</a></li>
                    {% when 'company' %}
                      <li><a href="/pages/ueber-uns" class="md-footer-col__link">Über uns</a></li>
                      <li><a href="/pages/praequalifizierung" class="md-footer-col__link">Präqualifizierung</a></li>
                      <li><a href="/pages/google-bewertungen" class="md-footer-col__link">Google Bewertungen</a></li>
                      <li><a href="/pages/produktgruppen" class="md-footer-col__link">Produktgruppen</a></li>
                      <li><a href="/pages/newsletter" class="md-footer-col__link">Newsletter</a></li>
                    {% when 'legal' %}
                      <li><a href="/policies/legal-notice" class="md-footer-col__link">Impressum</a></li>
                      <li><a href="/policies/privacy-policy" class="md-footer-col__link">Datenschutz</a></li>
                      <li><a href="/policies/terms-of-service" class="md-footer-col__link">AGB</a></li>
                      <li><a href="/policies/refund-policy" class="md-footer-col__link">Widerrufsbelehrung</a></li>
                      <li><a href="/pages/barrierefreiheit" class="md-footer-col__link">Barrierefreiheit</a></li>
                  {% endcase %}
                {% endif %}
              </ul>
            </details>
          </div>
        {% endfor %}

      </div>
    </div>
  </div>

  <div class="md-footer-bottom">
    <div class="md-footer-bottom__inner">
      <div class="md-footer-bottom__left">
        {% if section.settings.show_payment_icons %}
          <ul class="md-footer-bottom__payment" role="list">
            {% for type in shop.enabled_payment_types limit: 6 %}
              <li>{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
            {% endfor %}
          </ul>
        {% endif %}
        {% if section.settings.show_shipping_text and section.settings.shipping_text != blank %}
          <p class="md-footer-bottom__shipping">{{ section.settings.shipping_text | escape }}</p>
        {% endif %}
      </div>
      <div class="md-footer-bottom__right">
        {% if section.settings.show_legal_disclaimer and section.settings.legal_disclaimer_text != blank %}
          <p class="md-footer-bottom__legal">{{ section.settings.legal_disclaimer_text | escape }}</p>
        {% endif %}
        <p class="md-footer-bottom__copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
        </p>
      </div>
    </div>
  </div>
</footer>

