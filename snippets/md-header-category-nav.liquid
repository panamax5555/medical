<div class="md-header-catbar">
  <div class="md-header-catbar__inner">
    <div class="md-header-catmenu">
      <button
        class="md-header-catbtn"
        type="button"
        aria-expanded="false"
        aria-controls="md-header-category-flyout"
        aria-label="{{ section.settings.categories_label | escape }}"
      >
        <span class="md-header-catbtn__icon">
          <span></span><span></span><span></span>
        </span>
        {{ section.settings.categories_label | escape }}
      </button>
    </div>

    <div class="md-header-catflyout" id="md-header-category-flyout">
      {% assign cat_menu = section.settings.menu %}
      {% if cat_menu.links.size > 0 %}
        {% assign has_promo = false %}
        {% if section.settings.promo_image != blank or section.settings.promo_heading != blank %}
          {% assign has_promo = true %}
        {% endif %}

        <div class="md-header-catflyout__inner{% if has_promo %} md-header-catflyout__inner--has-promo{% endif %}">
          <div class="md-header-catflyout__rail">
            {% for link in cat_menu.links %}
              <button
                class="md-header-catflyout__rail-link"
                type="button"
                data-cat-index="{{ forloop.index0 }}"
              >
                <span>{{ link.title | escape }}</span>
                <svg class="md-header-catflyout__rail-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            {% endfor %}

            <div class="md-header-catflyout__quicklinks">
              {% if section.settings.quicklink_brands_url != blank %}
                <a href="{{ section.settings.quicklink_brands_url }}" class="md-header-catflyout__quicklink">
                  {{ section.settings.quicklink_brands_label | default: 'Marken' | escape }}
                </a>
              {% endif %}
              {% if section.settings.quicklink_sale_url != blank %}
                <a href="{{ section.settings.quicklink_sale_url }}" class="md-header-catflyout__quicklink">
                  {{ section.settings.quicklink_sale_label | default: 'Sale' | escape }}
                </a>
              {% endif %}
              {% if section.settings.quicklink_new_url != blank %}
                <a href="{{ section.settings.quicklink_new_url }}" class="md-header-catflyout__quicklink">
                  {{ section.settings.quicklink_new_label | default: 'Neuheiten' | escape }}
                </a>
              {% endif %}
              {% if section.settings.quicklink_topics_url != blank %}
                <a href="{{ section.settings.quicklink_topics_url }}" class="md-header-catflyout__quicklink">
                  {{ section.settings.quicklink_topics_label | default: 'Themen' | escape }}
                </a>
              {% endif %}
              {% if section.settings.quicklink_industries_url != blank %}
                <a href="{{ section.settings.quicklink_industries_url }}" class="md-header-catflyout__quicklink">
                  {{ section.settings.quicklink_industries_label | default: 'Branchen' | escape }}
                </a>
              {% endif %}
            </div>
          </div>

          <div class="md-header-catflyout__content">
            <div class="md-header-catflyout__panel">
              {% for link in cat_menu.links %}
                <div class="md-header-catflyout__panel-content" data-cat-index="{{ forloop.index0 }}">
                  <div class="md-header-catflyout__panel-header">
                    <h3 class="md-header-catflyout__panel-title">{{ link.title | escape }}</h3>
                    <a href="{{ link.url }}" class="md-header-catflyout__panel-all-link">
                      Alle anzeigen &rsaquo;
                    </a>
                  </div>
                  {% if link.links.size > 0 %}
                    <div class="md-header-catflyout__panel-grid">
                      {% assign sorted_childlinks = link.links | sort: 'title' %}
                      {% for childlink in sorted_childlinks %}
                        {% assign child_title = childlink.title | downcase %}
                        {% capture child_icon %}
                          {% if child_title contains 'handschuh' or child_title contains 'nitril' or child_title contains 'latex' or child_title contains 'vinyl' or child_title contains 'pe' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="6" height="16" rx="1"/><rect x="14" y="4" width="6" height="16" rx="1"/><line x1="7" y1="12" x2="17" y2="12"/></svg>
                          {% elsif child_title contains 'desinfekt' or child_title contains 'fläche' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L6 11c-2 4 1 7 6 7s8-3 6-7L12 2z"/><line x1="10" y1="15" x2="14" y2="15"/></svg>
                          {% elsif child_title contains 'praxis' or child_title contains 'organis' or child_title contains 'diagnos' or child_title contains 'untersuch' or child_title contains 'labor' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 4h6v3H9z"/><rect x="7" y="5" width="10" height="15" rx="1"/><line x1="10" y1="10" x2="14" y2="10"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
                          {% elsif child_title contains 'schutz' or child_title contains 'maske' or child_title contains 'ffp' or child_title contains 'kittel' or child_title contains 'schürz' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 4v5c0 5-3.5 10.5-8 12-4.5-1.5-8-7-8-12V6l8-4z"/><line x1="9" y1="11" x2="15" y2="11"/><line x1="12" y1="8" x2="12" y2="14"/></svg>
                          {% elsif child_title contains 'pflege' or child_title contains 'bett' or child_title contains 'inkontinenz' or child_title contains 'patient' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21l-7.7-7.7a5.5 5.5 0 017.7-7.8 5.5 5.5 0 017.7 7.8L12 21z"/></svg>
                          {% elsif child_title contains 'reinig' or child_title contains 'reiniger' or child_title contains 'tücher' or child_title contains 'müll' or child_title contains 'abfall' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="8" width="5" height="13" rx="1"/><path d="M12 13l2-2M15 10l3-3M19 14l-2 2"/><line x1="8.5" y1="3" x2="8.5" y2="8"/></svg>
                          {% elsif child_title contains 'papier' or child_title contains 'spender' or child_title contains 'toilette' or child_title contains 'handtuch' or child_title contains 'taschentuch' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="3" width="10" height="18" rx="2"/><line x1="10" y1="7" x2="14" y2="7"/><line x1="10" y1="11" x2="14" y2="11"/><line x1="10" y1="15" x2="12" y2="15"/></svg>
                          {% elsif child_title contains 'wund' or child_title contains 'pflaster' or child_title contains 'verbänd' or child_title contains 'verband' or child_title contains 'kompress' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="8" rx="2"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                          {% elsif child_title contains 'geschäft' or child_title contains 'b2b' or child_title contains 'rechnung' or child_title contains 'kondition' or child_title contains 'business' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/><line x1="12" y1="11" x2="12" y2="15"/></svg>
                          {% else %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L3 7v10l9 5 9-5V7l-9-5z"/><line x1="12" y1="12" x2="12" y2="22"/><line x1="3" y1="7" x2="12" y2="12"/><line x1="21" y1="7" x2="12" y2="12"/></svg>
                          {% endif %}
                        {% endcapture %}
                        <a href="{{ childlink.url }}" class="md-header-catflyout__panel-link">
                          <span class="md-header-catflyout__panel-icon">{{ child_icon }}</span>
                          <span class="md-header-catflyout__panel-text">{{ childlink.title | escape }}</span>
                        </a>
                      {% endfor %}
                    </div>
                  {% else %}
                    <div class="md-header-catflyout__panel-empty">
                      <a href="{{ link.url }}" class="md-header-catflyout__panel-link">
                        <span class="md-header-catflyout__panel-icon">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L3 7v10l9 5 9-5V7l-9-5z"/><line x1="12" y1="12" x2="12" y2="22"/><line x1="3" y1="7" x2="12" y2="12"/><line x1="21" y1="7" x2="12" y2="12"/></svg>
                        </span>
                        <span class="md-header-catflyout__panel-text">Zum Bereich &rsaquo;</span>
                      </a>
                    </div>
                  {% endif %}
                </div>
              {% endfor %}
            </div>

            {% if section.settings.brand_menu != blank %}
              {% assign brand_menu_handle = section.settings.brand_menu | strip %}
              {% if linklists[brand_menu_handle].links.size > 0 %}
                <div class="md-header-catflyout__brands">
                  <p class="md-header-catflyout__brands-title">Top Marken</p>
                  <div class="md-header-catflyout__brands-grid">
                    {% for brand_link in linklists[brand_menu_handle].links %}
                      <a href="{{ brand_link.url }}" class="md-header-catflyout__brands-link">
                        {{ brand_link.title | escape }}
                      </a>
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
            {% endif %}
          </div>

          {% if has_promo %}
            <div class="md-header-catflyout__promo has-content">
              {% if section.settings.promo_image != blank %}
                {% assign promo_alt = section.settings.promo_heading | default: 'Promo' | escape %}
                {{
                  section.settings.promo_image
                  | image_url: width: 520
                  | image_tag:
                    class: 'md-header-catflyout__promo-image',
                    alt: promo_alt,
                    loading: 'lazy'
                }}
              {% endif %}
              {% if section.settings.promo_heading != blank %}
                <h4 class="md-header-catflyout__promo-heading">{{ section.settings.promo_heading | escape }}</h4>
              {% endif %}
              {% if section.settings.promo_text != blank %}
                <p class="md-header-catflyout__promo-text">{{ section.settings.promo_text | escape }}</p>
              {% endif %}
              {% if section.settings.promo_link != blank and section.settings.promo_link_label != blank %}
                <a href="{{ section.settings.promo_link }}" class="md-header-catflyout__promo-link">
                  {{ section.settings.promo_link_label | escape }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <nav class="md-header-catbar__menu">
      {% if cat_menu.links.size > 0 %}
        <ul class="md-header-catbar__nav" role="list">
          {% for link in cat_menu.links limit: 6 %}
            <li class="md-header-catbar__nav-item">
              <a href="{{ link.url }}" class="md-header-catbar__nav-link">
                {{ link.title | escape }}
              </a>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </nav>

    {% if section.settings.show_b2b_hint %}
      {% render 'md-header-b2b-switch' %}
    {% endif %}
  </div>
</div>
