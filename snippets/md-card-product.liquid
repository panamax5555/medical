{% comment %}
  Renders a B2B product card for collections

  Accepts:
  - card_product: {Object} Product Liquid object
  - lazy_load: {Boolean} Lazy load image (default: true)
  - show_vendor: {Boolean} Show vendor (default: false)
  - show_rating: {Boolean} Show rating (default: false)
  - show_inventory: {Boolean} Show inventory status (default: false)
  - show_unit_price: {Boolean} Show unit price / base price (default: false)
  - show_variant_hint: {Boolean} Show variant count hint (default: false)
  - section_id: {String} Section ID for unique IDs

  Usage:
  {% render 'md-card-product',
    card_product: product,
    show_vendor: section.settings.show_vendor,
    show_rating: section.settings.show_rating,
    show_inventory: section.settings.show_inventory,
    show_unit_price: section.settings.show_unit_price,
    show_variant_hint: section.settings.show_variant_hint,
    lazy_load: lazy_load,
    section_id: section.id
  %}
{% endcomment %}

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign featured_media = card_product.featured_media
    assign product_url = card_product.url
    assign current_variant = card_product.selected_or_first_available_variant
    assign compare_at_price = current_variant.compare_at_price
    assign price = current_variant.price
    assign available = current_variant.available

    assign money_price_md = price | money_without_currency | append: ' €'
    assign money_compare_at_price_md = ''
    if compare_at_price > price and available
      assign money_compare_at_price_md = compare_at_price | money_without_currency | append: ' €'
    endif

    assign on_sale = false
    if compare_at_price > price and available
      assign on_sale = true
    endif

    assign unit_price_md = ''
    if show_unit_price and current_variant.unit_price_measurement
      assign unit_price_md = current_variant.unit_price | money_without_currency | append: ' €'
    endif

    assign variant_count = card_product.variants_count
    assign product_images = card_product.images
  -%}

  <div class="md-card-product">
    <div class="md-card-product__inner">
      {%- if show_variant_hint and variant_count > 1 -%}
        <div class="md-card-product__watchlist">
          {% comment %} Reserved for watchlist toggle {% endcomment %}
        </div>
      {%- endif -%}

      <div class="md-card-product__media" data-md-card-media>
        <a href="{{ product_url }}" class="md-card-product__media-link" aria-label="{{ card_product.title | escape }}">
          <div class="md-card-product__media-track" data-md-card-media-track>
            {%- if product_images.size > 0 -%}
              {%- for image in product_images limit: 6 -%}
                {%- assign is_first = false -%}
                {%- if forloop.first -%}{%- assign is_first = true -%}{%- endif -%}
                <div class="md-card-product__media-slide" data-md-card-media-slide>
                  <img
                    srcset="
                      {%- if image.width >= 165 -%}{{ image | image_url: width: 165 }} 165w,{%- endif -%}
                      {%- if image.width >= 360 -%}{{ image | image_url: width: 360 }} 360w,{%- endif -%}
                      {%- if image.width >= 533 -%}{{ image | image_url: width: 533 }} 533w,{%- endif -%}
                      {%- if image.width >= 720 -%}{{ image | image_url: width: 720 }} 720w,{%- endif -%}
                      {%- if image.width >= 940 -%}{{ image | image_url: width: 940 }} 940w,{%- endif -%}
                      {{ image | image_url }} {{ image.width }}w
                    "
                    src="{{ image | image_url: width: 360 }}"
                    sizes="(min-width: 990px) calc((100vw - 27vw) / 4), (min-width: 750px) calc(100vw / 3), (min-width: 480px) calc(100vw / 2), 100vw"
                    alt="{{ image.alt | default: card_product.title | escape }}"
                    class="md-card-product__image"
                    width="{{ image.width }}"
                    height="{{ image.height }}"
                    {%- if lazy_load and is_first == false -%}
                      loading="lazy"
                    {%- endif -%}
                  >
                </div>
              {%- endfor -%}
            {%- elsif featured_media -%}
              <div class="md-card-product__media-slide" data-md-card-media-slide>
                <img
                  srcset="
                    {%- if featured_media.width >= 165 -%}{{ featured_media | image_url: width: 165 }} 165w,{%- endif -%}
                    {%- if featured_media.width >= 360 -%}{{ featured_media | image_url: width: 360 }} 360w,{%- endif -%}
                    {%- if featured_media.width >= 533 -%}{{ featured_media | image_url: width: 533 }} 533w,{%- endif -%}
                    {%- if featured_media.width >= 720 -%}{{ featured_media | image_url: width: 720 }} 720w,{%- endif -%}
                    {%- if featured_media.width >= 940 -%}{{ featured_media | image_url: width: 940 }} 940w,{%- endif -%}
                    {{ featured_media | image_url }} {{ featured_media.width }}w
                  "
                  src="{{ featured_media | image_url: width: 360 }}"
                  sizes="(min-width: 990px) calc((100vw - 27vw) / 4), (min-width: 750px) calc(100vw / 3), (min-width: 480px) calc(100vw / 2), 100vw"
                  alt="{{ featured_media.alt | default: card_product.title | escape }}"
                  class="md-card-product__image"
                  width="{{ featured_media.width }}"
                  height="{{ featured_media.height }}"
                >
              </div>
            {%- else -%}
              <div class="md-card-product__media-slide" data-md-card-media-slide>
                {{ 'product-apparel-2' | placeholder_svg_tag: 'md-card-product__image' }}
              </div>
            {%- endif -%}
          </div>
        </a>

        {%- if product_images.size > 1 -%}
          <button
            type="button"
            class="md-card-product__media-nav md-card-product__media-nav--prev"
            aria-label="Vorheriges Produktbild"
            data-md-card-media-prev
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button
            type="button"
            class="md-card-product__media-nav md-card-product__media-nav--next"
            aria-label="Nächstes Produktbild"
            data-md-card-media-next
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        {%- endif -%}

        {%- if product_images.size > 1 -%}
          <div class="md-card-product__media-pagination" data-md-card-media-pagination aria-hidden="true">
            {%- for image in product_images -%}
              <button
                type="button"
                class="md-card-product__media-dot{% if forloop.first %} is-active{% endif %}"
                data-md-card-media-dot
                data-md-card-media-dot-index="{{ forloop.index0 }}"
                aria-label="Bild {{ forloop.index }} anzeigen"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- liquid
          assign brand_logo = blank
          assign brand_logo_src = blank
          assign brand_name = card_product.vendor | default: card_product.title | escape

          assign brand_metaobject = card_product.metafields.custom.brand_ref.value
          if brand_metaobject == blank
            assign brand_metaobject = card_product.metafields.custom.brand.value
          endif

          if brand_metaobject != blank
            if brand_metaobject.name.value != blank
              assign brand_name = brand_metaobject.name.value | escape
            elsif brand_metaobject.name != blank
              assign brand_name = brand_metaobject.name | escape
            endif

            if brand_metaobject.logo.value != blank
              assign brand_logo = brand_metaobject.logo.value
            elsif brand_metaobject.logo != blank
              assign brand_logo = brand_metaobject.logo
            endif
          endif

          if brand_logo == blank and card_product.metafields.custom.brand_logo.value != blank
            assign brand_logo = card_product.metafields.custom.brand_logo.value
          endif

          if brand_logo != blank
            assign brand_logo_src = brand_logo | image_url: width: 320
          endif
        -%}

        {%- if brand_logo_src != blank -%}
          <div class="md-card-product__brand-logo">
            <img
              src="{{ brand_logo_src }}"
              alt="{{ brand_name }}"
              width="200"
              height="50"
              loading="lazy"
            >
          </div>
        {%- endif -%}
      </div>

      <div class="md-card-product__info">
        <div class="md-card-product__text">
          {%- if show_vendor and card_product.vendor != blank -%}
            <span class="md-card-product__vendor">{{ card_product.vendor | escape }}</span>
          {%- endif -%}

          <h3 class="md-card-product__title">
            <a href="{{ product_url }}" class="md-card-product__title-link">
              {{- card_product.title | escape -}}
            </a>
          </h3>

          {%- liquid
            assign short_description = card_product.metafields.custom.short_description | default: card_product.metafields.custom.kurzbeschreibung | strip
          -%}
          {%- if short_description != blank -%}
            <span class="md-card-product__subtitle">{{ short_description | escape | truncate: 100 }}</span>
          {%- endif -%}

          {%- liquid
            assign variant_label = ''
            if current_variant.title != blank and current_variant.title != 'Default Title'
              assign variant_label = current_variant.title
            elsif current_variant.option1 != blank and current_variant.option1 != 'Default Title'
              assign variant_label = current_variant.option1
            elsif card_product.metafields.custom.gebinde != blank
              assign variant_label = card_product.metafields.custom.gebinde
            elsif card_product.metafields.custom.vpe != blank
              assign variant_label = card_product.metafields.custom.vpe
            elsif card_product.metafields.custom.unit != blank
              assign variant_label = card_product.metafields.custom.unit
            elsif card_product.metafields.custom.inhalt != blank
              assign variant_label = card_product.metafields.custom.inhalt
            endif
          -%}
          {%- if variant_label != '' -%}
            <span class="md-card-product__description">{{ variant_label | escape }}</span>
          {%- endif -%}

          {%- if show_rating -%}
            {%- if card_product.metafields.reviews.rating.value != blank -%}
              {%- liquid
                assign rating_value = card_product.metafields.reviews.rating.value.rating | times: 1.0
                assign rating_max = card_product.metafields.reviews.rating.value.scale_max | times: 1.0
                assign rating_count = card_product.metafields.reviews.rating_count | default: 0
              -%}
              <div class="md-card-product__rating" aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: rating_value, rating_max: rating_max }}">
                <span class="md-card-product__rating-stars" aria-hidden="true">
                  {%- for i in (1..5) -%}
                    {%- assign half_star = i | minus: 0.5 -%}
                    {%- if rating_value >= i -%}
                      <svg class="md-card-product__rating-star" viewBox="0 0 14 14" fill="currentColor"><path d="M7 0l1.66 5.1H14l-4.33 3.15L11.33 14 7 10.85 2.67 14l1.66-5.75L0 5.1h5.34L7 0z"/></svg>
                    {%- elsif rating_value >= half_star -%}
                      <svg class="md-card-product__rating-star" viewBox="0 0 14 14" fill="currentColor"><path d="M7 0l1.66 5.1H14L9.67 8.25 11.33 14 7 10.85V0z"/></svg>
                    {%- else -%}
                      <svg class="md-card-product__rating-star" viewBox="0 0 14 14" fill="currentColor" opacity="0.25"><path d="M7 0l1.66 5.1H14l-4.33 3.15L11.33 14 7 10.85 2.67 14l1.66-5.75L0 5.1h5.34L7 0z"/></svg>
                    {%- endif -%}
                  {%- endfor -%}
                </span>
                {%- if rating_count > 0 -%}
                  <span aria-hidden="true">({{ rating_count }})</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endif -%}

          <div class="md-card-product__prices">
            {%- if on_sale -%}
              <span class="md-card-product__price-old">{{ money_compare_at_price_md }}</span>
            {%- endif -%}
            <span class="md-card-product__price-current{% if on_sale %} md-card-product__price-current--discount{% endif %}">
              {{- money_price_md -}}
            </span>

            {%- if unit_price_md != '' -%}
              <span class="md-card-product__unit-price">
                {{ unit_price_md }}
                /
                {%- if current_variant.unit_price_measurement.reference_value != 1 -%}
                  {{- current_variant.unit_price_measurement.reference_value }}
                {%- endif -%}
                {{- current_variant.unit_price_measurement.reference_unit -}}
              </span>
            {%- endif -%}
          </div>

          {%- if show_inventory -%}
            {%- if available -%}
              <span class="md-card-product__inventory">Auf Lager</span>
            {%- else -%}
              <span class="md-card-product__inventory md-card-product__inventory--unavailable">
                {{- 'products.product.sold_out' | t -}}
              </span>
            {%- endif -%}
          {%- endif -%}

          {%- if show_variant_hint and variant_count > 1 -%}
            <div class="md-card-product__variant-hint">
              <div class="md-card-product__variant-count">{{ variant_count }} Packgr&ouml;&szlig;en</div>
            </div>
          {%- endif -%}
        </div>

      {%- if show_variant_hint and variant_count > 1 -%}
        <div class="md-card-product__variant-popover">
          <div class="md-card-product__variant-list">
            {%- for variant in card_product.variants limit: 6 -%}
              {%- liquid
                assign tile_media = variant.featured_media | default: variant.image | default: featured_media
                assign variant_label_clean = ''

                if variant.title != blank and variant.title != 'Default Title'
                  assign variant_label_clean = variant.title | strip
                elsif variant.option1 != blank and variant.option1 != 'Default Title'
                  assign variant_label_clean = variant.option1 | strip
                endif

                if variant_label_clean == blank
                  if variant.metafields.custom.vpe != blank
                    assign variant_label_clean = variant.metafields.custom.vpe | strip
                  elsif variant.metafields.custom.inhalt != blank
                    assign variant_label_clean = variant.metafields.custom.inhalt | strip
                  elsif variant.metafields.custom.menge != blank
                    assign variant_label_clean = variant.metafields.custom.menge | strip
                  elsif variant.metafields.custom.gebinde != blank
                    assign variant_label_clean = variant.metafields.custom.gebinde | strip
                  else
                    assign variant_label_clean = card_product.title | strip
                  endif
                endif
              -%}
              <a href="{{ product_url }}?variant={{ variant.id }}" class="md-card-product__variant-tile" title="{{ variant_label_clean | escape }}">
                {%- if tile_media -%}
                  <img
                    src="{{ tile_media | image_url: width: 80 }}"
                    srcset="{{ tile_media | image_url: width: 80 }} 1x, {{ tile_media | image_url: width: 160 }} 2x"
                    alt="{{ variant_label_clean | escape }}"
                    class="md-card-product__variant-image"
                    width="80"
                    height="80"
                    loading="lazy"
                  >
                {%- endif -%}
                <span class="md-card-product__variant-label">
                  {{- variant_label_clean | truncate: 24 -}}
                </span>
              </a>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- if variant_count > 1 -%}
        <div class="md-card-product__variant-control" data-md-variant-dropdown>
          {%- liquid
            assign trigger_size = current_variant.title | replace: 'Default Title', '' | strip
            assign trigger_vpe = current_variant.metafields.custom.vpe | default: current_variant.metafields.custom.inhalt | default: current_variant.metafields.custom.menge | default: current_variant.metafields.custom.gebinde | default: card_product.metafields.custom.vpe | default: card_product.metafields.custom.inhalt | default: card_product.metafields.custom.menge | default: card_product.metafields.custom.gebinde | strip

            if trigger_vpe != blank and trigger_size != blank
              assign trigger_label = trigger_vpe | append: ', Größe ' | append: trigger_size
            elsif trigger_vpe != blank
              assign trigger_label = trigger_vpe
            elsif trigger_size != blank
              assign trigger_label = trigger_size
            else
              assign trigger_label = card_product.title | strip
            endif
          -%}
          <button type="button" class="md-card-product__variant-trigger" data-md-variant-trigger aria-expanded="false" aria-haspopup="listbox">
            <span class="md-card-product__variant-trigger-dot{% if available %} is-available{% endif %}" aria-hidden="true"></span>
            {%- assign variant_image = current_variant.featured_media | default: current_variant.image | default: featured_media -%}
            {%- if variant_image -%}
              <img src="{{ variant_image | image_url: width: 96 }}" srcset="{{ variant_image | image_url: width: 96 }} 1x, {{ variant_image | image_url: width: 192 }} 2x" alt="" class="md-card-product__variant-trigger-image" width="96" height="96" aria-hidden="true">
            {%- endif -%}
            <span class="md-card-product__variant-trigger-label" data-md-variant-trigger-label>{{- trigger_label | escape -}}</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 10 6" width="10" height="6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="md-card-product__variant-menu" data-md-variant-menu role="listbox">
            {%- for variant in card_product.variants -%}
              {%- liquid
                assign v_size = variant.title | replace: 'Default Title', '' | strip
                assign v_vpe = variant.metafields.custom.vpe | default: variant.metafields.custom.inhalt | default: variant.metafields.custom.menge | default: variant.metafields.custom.gebinde | default: card_product.metafields.custom.vpe | default: card_product.metafields.custom.inhalt | default: card_product.metafields.custom.menge | default: card_product.metafields.custom.gebinde | strip

                if v_vpe != blank and v_size != blank
                  assign v_label = v_vpe | append: ', Größe ' | append: v_size
                elsif v_vpe != blank
                  assign v_label = v_vpe
                elsif v_size != blank
                  assign v_label = v_size
                else
                  assign v_label = card_product.title | strip
                endif
              -%}
              <button
                type="button"
                class="md-card-product__variant-option{% if variant.id == current_variant.id %} is-active{% endif %}"
                data-md-variant-option
                data-variant-id="{{ variant.id }}"
                data-variant-price="{{ variant.price | money_without_currency | append: ' €' }}"
                {%- if variant.compare_at_price and variant.compare_at_price > variant.price %}
                  data-variant-compare-price="{{ variant.compare_at_price | money_without_currency | append: ' €' }}"
                {%- endif -%}
                {%- if variant.unit_price_measurement %}
                  data-variant-unit-price="{{ variant.unit_price | money_without_currency | append: ' €' }}"
                {%- endif -%}
                {%- if variant.unit_price_measurement and variant.unit_price_measurement.reference_value != 1 %}
                  data-variant-unit-ref-value="{{ variant.unit_price_measurement.reference_value }}"
                {%- endif -%}
                {%- if variant.unit_price_measurement %}
                  data-variant-unit-ref-unit="{{ variant.unit_price_measurement.reference_unit }}"
                {%- endif -%}
                data-variant-available="{{ variant.available }}"
                data-variant-title="{{ v_label | escape }}"
                data-variant-image="{%- if variant.featured_media -%}{{ variant.featured_media | image_url: width: 96 }}{%- elsif variant.image -%}{{ variant.image | image_url: width: 96 }}{%- else -%}{% if featured_media %}{{ featured_media | image_url: width: 96 }}{% endif %}{%- endif -%}"
                role="option"
                aria-selected="{% if variant.id == current_variant.id %}true{% else %}false{% endif %}"
                {% unless variant.available %}disabled{% endunless %}
              >
                <span class="md-card-product__variant-option-dot{% if variant.available %} is-available{% endif %}" aria-hidden="true"></span>
                {%- assign opt_media = variant.featured_media | default: variant.image | default: featured_media -%}
                {%- if opt_media -%}
                  <img src="{{ opt_media | image_url: width: 96 }}" srcset="{{ opt_media | image_url: width: 96 }} 1x, {{ opt_media | image_url: width: 192 }} 2x" alt="" class="md-card-product__variant-option-image" width="96" height="96" loading="lazy">
                {%- endif -%}
                <span class="md-card-product__variant-option-label">{{- v_label | escape -}}</span>
              </button>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
      </div>

      <form method="post" action="{{ routes.cart_add_url }}" class="md-card-product__purchase">
        <div class="md-card-product__purchase-price" data-md-purchase-price>
          <span class="md-card-product__purchase-price-current">
            {{- money_price_md -}}
          </span>
          {%- if on_sale -%}
            <span class="md-card-product__purchase-price-old">{{ money_compare_at_price_md }}</span>
          {%- endif -%}
        </div>

        <div class="md-card-product__purchase-meta">
          <span class="md-card-product__tax-note">inkl. MwSt. | <a href="/pages/versand-lieferung" class="md-card-product__tax-link">zzgl. Versand</a></span>
          {%- if unit_price_md != '' -%}
            <span class="md-card-product__purchase-unit-price">
              {{ unit_price_md }}
              /
              {%- if current_variant.unit_price_measurement.reference_value != 1 -%}
                {{- current_variant.unit_price_measurement.reference_value }}
              {%- endif -%}
              {{- current_variant.unit_price_measurement.reference_unit -}}
            </span>
          {%- endif -%}
        </div>

        {%- if show_inventory -%}
          <span class="md-card-product__purchase-inventory" data-md-purchase-inventory>
            {%- if available -%}
              Auf Lager
            {%- else -%}
              {{- 'products.product.sold_out' | t -}}
            {%- endif -%}
          </span>
        {%- endif -%}

        <input type="hidden" name="id" value="{{ current_variant.id }}">

        <div class="md-card-product__quantity">
          <button type="button" class="md-card-product__quantity-btn" data-md-quantity-minus aria-label="Menge verringern">&minus;</button>
          <input type="number" name="quantity" value="1" min="1" class="md-card-product__quantity-input" aria-label="Menge">
          <button type="button" class="md-card-product__quantity-btn" data-md-quantity-plus aria-label="Menge erhöhen">+</button>
        </div>

        <button type="submit" class="md-card-product__add-btn" data-md-purchase-submit {% unless available %}disabled{% endunless %}>
          {%- if available -%}
            {{- 'products.product.add_to_cart' | t -}}
          {%- else -%}
            {{- 'products.product.sold_out' | t -}}
          {%- endif -%}
        </button>
      </form>
    </div>
  </div>
{%- else -%}
  {% comment %} Placeholder card for editor preview {% endcomment %}
  <div class="md-card-product">
    <div class="md-card-product__inner">
      <div class="md-card-product__media" data-md-card-media>
        <div class="md-card-product__media-link" style="cursor: default;">
          <div class="md-card-product__media-track" data-md-card-media-track>
            <div class="md-card-product__media-slide" data-md-card-media-slide>
              {{ 'product-apparel-2' | placeholder_svg_tag: 'md-card-product__image' }}
            </div>
          </div>
        </div>
      </div>
      <div class="md-card-product__info">
        <div class="md-card-product__text">
          <h3 class="md-card-product__title">{{ 'onboarding.product_title' | t }}</h3>
          <div class="md-card-product__prices">
            <span class="md-card-product__price-current">19,99 &euro;</span>
          </div>
        </div>
      </div>
    </div>
  </div>
{%- endif -%}
